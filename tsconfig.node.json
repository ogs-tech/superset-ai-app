{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "lib": ["ES2022"],
    "types": ["node"],
    "outDir": "./out/types/node",
    "noEmit": true
  },
  "include": [
    "src/main/**/*.ts",
    "src/preload/**/*.ts",
    "src/shared/**/*.ts",
    "tests/main/**/*.ts",
    "tests/shared/**/*.ts",
    "electron.vite.config.ts",
    "vitest.config.ts",
    "eslint.config.js"
  ]
}
